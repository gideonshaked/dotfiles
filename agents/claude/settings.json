{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "claude-validate",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "beads@beads-marketplace": true,
    "ralph-loop@claude-plugins-official": true,
    "agentic-peer-review@agentic-peer-review": true,
    "hf-cli@huggingface-skills": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "beads-marketplace": {
      "source": {
        "source": "github",
        "repo": "steveyegge/beads"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "agentic-peer-review": {
      "source": {
        "source": "github",
        "repo": "gideonshaked/agentic-peer-review"
      }
    },
    "huggingface-skills": {
      "source": {
        "source": "github",
        "repo": "huggingface/skills"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Refuckulating",
      "Sacrificing a rubber duck to the code gods",
      "Committing crimes against clean code",
      "Doing unspeakable things to your codebase",
      "Making the linter cry",
      "Absolute fuckery in progress",
      "Violating every best practice known to man",
      "420 compile it",
      "Edibles kicking in... please wait",
      "Toking on your tokens",
      "Kidnapping the compiler's family and holding them for ransom",
      "Fucking up your codebase in the most creative ways possible",
      "Summoning the dark spirits of technical debt",
      "Making you regret every decision that led to this moment",
      "Turning your code into a dumpster fire",
      "Killing all of the joy in your life, one line of code at a time",
      "Go fuck yourself",
      "Quiet quitting",
      "Just fucking shit up left and right",
      "Selling your social security number on the dark web"
    ]
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "kitty",
  "autoCompactEnabled": false,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
