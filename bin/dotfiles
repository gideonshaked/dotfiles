#!/usr/bin/env bash
#
# Dotfiles management functions
#

if [ -d "$HOME/Documents/personal/dev/dotfiles" ]; then
    DOTFILES="$HOME/Documents/personal/dev/dotfiles"
elif [ -d "$HOME/dotfiles" ]; then
    DOTFILES="$HOME/dotfiles"
else
    echo "dotfiles repo not found" >&2
    exit 1
fi

# Update file that tracks installed Homebrew packages
update_brewfile() {
    brew bundle dump --all --force --file "$DOTFILES/manifest/Brewfile"
}

# Update Dotbot
update_dotbot() {
    cd $DOTFILES && git submodule update --remote dotbot
}

# Update Claude skills submodule
update_skills() {
    cd $DOTFILES && git submodule update --remote claude/claude-skills
}

# Update dotfiles
dfu() {
    cd "$DOTFILES" && git pull --ff-only && ./install
}

# Main function to run appropriate function based on argument
main() {
    case "$1" in
        "update_brewfile"|"brewfile")
            update_brewfile
            ;;
        "update_dotbot"|"dotbot")
            update_dotbot
            ;;
        "update_skills"|"skills")
            update_skills
            ;;
        "dfu"|"update")
            dfu
            ;;
        *)
            echo "Usage: dotfiles {brewfile|dotbot|skills|update}"
            echo ""
            echo "Available functions:"
            echo "  update_brewfile, brewfile  - Update Homebrew package manifest"
            echo "  update_dotbot, dotbot      - Update Dotbot submodule"
            echo "  update_skills, skills      - Update Claude skills submodule"
            echo "  dfu, update                - Update dotfiles and run install"
            exit 1
            ;;
    esac
}

# Run main function with all arguments
main "$@"
