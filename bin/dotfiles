#!/usr/bin/env bash
#
# Dotfiles management functions
#

# Resolve the dotfiles repo root. Prefer the exported $DOTFILES, then derive it
# from this script's real location (~/bin/dotfiles symlinks into <repo>/bin),
# then fall back to common clone paths.
if [ -n "${DOTFILES:-}" ] && [ -d "$DOTFILES" ]; then
    :
else
    SOURCE="${BASH_SOURCE[0]}"
    while [ -L "$SOURCE" ]; do
        DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
        SOURCE="$(readlink "$SOURCE")"
        [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"
    done
    DOTFILES="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
fi

if [ ! -d "$DOTFILES" ]; then
    if [ -d "$HOME/Documents/personal/dev/dotfiles" ]; then
        DOTFILES="$HOME/Documents/personal/dev/dotfiles"
    elif [ -d "$HOME/dotfiles" ]; then
        DOTFILES="$HOME/dotfiles"
    else
        echo "dotfiles repo not found" >&2
        exit 1
    fi
fi

# Update file that tracks installed Homebrew packages
update_brewfile() {
    brew bundle dump --force --file "$DOTFILES/manifest/Brewfile"
}

# Install packages from the manifest. With --only-plugins, install just the
# tracked VS Code extensions; otherwise install everything via brew bundle.
install_brew() {
    local brewfile="$DOTFILES/manifest/Brewfile"

    if [ "${1:-}" = "--only-plugins" ]; then
        if ! command -v code >/dev/null 2>&1; then
            echo "code CLI not found, cannot install plugins" >&2
            exit 1
        fi
        grep -E '^vscode "' "$brewfile" | sed -E 's/^vscode "([^"]*)".*/\1/' | while read -r ext; do
            [ -n "$ext" ] && code --install-extension "$ext"
        done
        return
    fi

    if ! command -v brew >/dev/null 2>&1; then
        echo "brew not found" >&2
        exit 1
    fi
    brew bundle install --file "$brewfile"
}

# Update Dotbot
update_dotbot() {
    cd "$DOTFILES" && git submodule update --remote dotbot
}

# Update dotfiles
dfu() {
    cd "$DOTFILES" && git pull --ff-only && ./install "$@"
}

# Main function to run appropriate function based on argument
main() {
    case "$1" in
        "update_brewfile"|"brewfile")
            update_brewfile
            ;;
        "install_brew"|"brew")
            shift
            install_brew "$@"
            ;;
        "update_dotbot"|"dotbot")
            update_dotbot
            ;;
        "dfu"|"update")
            shift
            dfu "$@"
            ;;
        *)
            echo "Usage: dotfiles {brewfile|brew|dotbot|update}"
            echo ""
            echo "Available functions:"
            echo "  update_brewfile, brewfile  - Update Homebrew package manifest"
            echo "  install_brew, brew         - Install packages from the manifest"
            echo "                               (--only-plugins for just VS Code extensions)"
            echo "  update_dotbot, dotbot      - Update Dotbot submodule"
            echo "  dfu, update                - Update dotfiles and run install"
            exit 1
            ;;
    esac
}

# Run main function with all arguments
main "$@"
