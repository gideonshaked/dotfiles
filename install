#!/usr/bin/env bash

set -e

CONFIG="install.conf.yaml"
DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Parse flags: strip our own args, pass the rest to dotbot
ARGS=()
for arg in "$@"; do
    case "$arg" in
        --minimal) CONFIG="install-minimal.conf.yaml" ;;
        *) ARGS+=("$arg") ;;
    esac
done

cd "${BASEDIR}"
(cd "${DOTBOT_DIR}" && git submodule sync --quiet --recursive)
git submodule update --init --recursive "${DOTBOT_DIR}"

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${ARGS[@]}"

# claude-skills: private submodule, skip if unavailable
SKILLS_DIR="claude/claude-skills"
if [ ! -d "${BASEDIR}/${SKILLS_DIR}/.git" ] && [ ! -f "${BASEDIR}/${SKILLS_DIR}/.git" ]; then
    git submodule update --init "${SKILLS_DIR}" 2>/dev/null || true
fi
if [ -d "${BASEDIR}/${SKILLS_DIR}/commands" ]; then
    "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c install-skills.conf.yaml "${ARGS[@]}"
else
    echo "Skipping claude-skills (private submodule not available)"
fi
