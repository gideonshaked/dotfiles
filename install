#!/usr/bin/env bash

set -e

CONFIG="install.conf.yaml"
MODE="full"
DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Parse flags: strip our own args, pass the rest to dotbot
ARGS=()
for arg in "$@"; do
    case "$arg" in
        --minimal) MODE="minimal" ;;
        *) ARGS+=("$arg") ;;
    esac
done

cd "${BASEDIR}"
git submodule update --init --recursive "${DOTBOT_DIR}"

DOTFILES_INSTALL_MODE="${MODE}" "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${ARGS[@]}"
