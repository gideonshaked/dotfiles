#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
NPX_CMD="${DOTFILES_NPX:-$DOTFILES_DIR/scripts/dotfiles-npx}"

if ! "$NPX_CMD" --version >/dev/null 2>&1; then
    echo "npx not found, skipping ccstatusline (non-fatal)"
    exit 0
fi

if "$NPX_CMD" -y --package ccstatusline@latest node -e "process.exit(0)" 2>/dev/null; then
    echo "ccstatusline OK"
else
    echo "ccstatusline install failed (non-fatal)"
fi
