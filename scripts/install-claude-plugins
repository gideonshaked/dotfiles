#!/usr/bin/env bash

set -euo pipefail

PATH="${HOME}/bin:${HOME}/.local/bin:${HOME}/.bun/bin:${HOME}/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"
export PATH

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    # shellcheck disable=SC1091
    . "$NVM_DIR/nvm.sh"
    nvm use --silent default >/dev/null 2>&1 || nvm use --silent --lts >/dev/null 2>&1 || true
fi

if ! which claude >/dev/null 2>&1; then
    echo "claude CLI not found, skipping plugins (non-fatal)"
    exit 0
fi

if ! which jq >/dev/null 2>&1; then
    echo "jq not found, skipping plugins (non-fatal)"
    exit 0
fi

SETTINGS="${HOME}/.claude/settings.json"
if [ ! -f "$SETTINGS" ]; then
    echo "settings.json not found, skipping plugins (non-fatal)"
    exit 0
fi

jq -r '.extraKnownMarketplaces // {} | to_entries[] | .value.source.repo' "$SETTINGS" | while read -r repo; do
    [ -n "$repo" ] || continue
    claude plugins marketplace add "$repo" >/dev/null 2>&1 || true
done

jq -r '.enabledPlugins // {} | to_entries[] | select(.value == true) | .key' "$SETTINGS" | while read -r plugin; do
    [ -n "$plugin" ] || continue
    claude plugins install "$plugin" >/dev/null 2>&1 || claude plugins update "$plugin" >/dev/null 2>&1 || true
done

echo "Claude plugins OK"
