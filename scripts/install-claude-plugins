#!/usr/bin/env bash

set -euo pipefail

if ! command -v claude >/dev/null 2>&1; then
    echo "claude CLI not found, skipping plugins (non-fatal)"
    exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
    echo "jq not found, skipping plugins (non-fatal)"
    exit 0
fi

SETTINGS="${HOME}/.claude/settings.json"
if [ ! -f "$SETTINGS" ]; then
    echo "settings.json not found, skipping plugins (non-fatal)"
    exit 0
fi

jq -r '.extraKnownMarketplaces // {} | to_entries[] | .value.source.repo' "$SETTINGS" | while read -r repo; do
    [ -n "$repo" ] || continue
    echo "Adding Claude marketplace: $repo"
    claude plugins marketplace add "$repo" || true
done

jq -r '.enabledPlugins // {} | to_entries[] | select(.value == true) | .key' "$SETTINGS" | while read -r plugin; do
    [ -n "$plugin" ] || continue
    echo "Installing/updating Claude plugin: $plugin"
    claude plugins install "$plugin" 2>/dev/null || claude plugins update "$plugin" 2>/dev/null || true
done

echo "Claude plugins OK"
