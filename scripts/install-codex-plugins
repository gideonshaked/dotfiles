#!/usr/bin/env bash

set -euo pipefail

PATH="${HOME}/bin:${HOME}/.local/bin:${HOME}/.bun/bin:${HOME}/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"
export PATH

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    # shellcheck disable=SC1091
    . "$NVM_DIR/nvm.sh"
    nvm use --silent default >/dev/null 2>&1 || nvm use --silent --lts >/dev/null 2>&1 || true
fi

if ! which codex >/dev/null 2>&1; then
    echo "codex CLI not found, skipping plugins (non-fatal)"
    exit 0
fi

CONFIG="${CODEX_HOME:-${HOME}/.codex}/config.toml"
if [ ! -f "$CONFIG" ]; then
    echo "config.toml not found, skipping plugins (non-fatal)"
    exit 0
fi

codex plugin marketplace upgrade >/dev/null 2>&1 || true

if ! codex debug prompt-input "plugin cache warmup" >/dev/null 2>&1; then
    echo "Codex plugin discovery refresh failed (non-fatal)"
fi

echo "Codex plugins OK"
