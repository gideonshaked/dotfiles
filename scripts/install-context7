#!/usr/bin/env bash

set -euo pipefail

CONFIG="${CODEX_HOME:-${HOME}/.codex}/config.toml"
AGENTS="${CODEX_HOME:-${HOME}/.codex}/AGENTS.md"
SECRETS="${HOME}/.zsh/secrets.zsh"

write_context7_secret() {
    local key="$1"
    local tmp

    [ -n "$key" ] || return 0

    mkdir -p "$(dirname "$SECRETS")"
    touch "$SECRETS"
    chmod 600 "$SECRETS"

    tmp="$(mktemp)"
    grep -v '^export CONTEXT7_API_KEY=' "$SECRETS" > "$tmp" || true
    printf 'export CONTEXT7_API_KEY=%q\n' "$key" >> "$tmp"
    mv -f "$tmp" "$SECRETS"
    chmod 600 "$SECRETS"
}

static_context7_key() {
    local config="$1"

    [ -f "$config" ] || return 0

    awk '
        $0 == "[mcp_servers.context7.http_headers]" {
            in_context7_headers = 1
            next
        }
        in_context7_headers && $0 ~ /^\[/ {
            in_context7_headers = 0
        }
        in_context7_headers && $0 ~ /^CONTEXT7_API_KEY[[:space:]]*=/ {
            sub(/^[^=]*=[[:space:]]*"/, "")
            sub(/".*$/, "")
            print
            exit
        }
    ' "$config"
}

normalize_codex_config() {
    local config="$1"
    local key
    local tmp

    [ -f "$config" ] || return 0

    key="$(static_context7_key "$config")"
    if [ -n "$key" ] && [ -z "${CONTEXT7_API_KEY:-}" ]; then
        write_context7_secret "$key"
        echo "Moved Context7 API key to ~/.zsh/secrets.zsh"
    fi

    tmp="$(mktemp)"
    awk '
        $0 == "[mcp_servers.context7.http_headers]" {
            print "[mcp_servers.context7.env_http_headers]"
            in_context7_headers = 1
            wrote_key = 0
            next
        }
        in_context7_headers && $0 ~ /^\[/ {
            if (!wrote_key) {
                print "CONTEXT7_API_KEY = \"CONTEXT7_API_KEY\""
            }
            in_context7_headers = 0
        }
        in_context7_headers && $0 ~ /^CONTEXT7_API_KEY[[:space:]]*=/ {
            if (!wrote_key) {
                print "CONTEXT7_API_KEY = \"CONTEXT7_API_KEY\""
                wrote_key = 1
            }
            next
        }
        {
            print
        }
        END {
            if (in_context7_headers && !wrote_key) {
                print "CONTEXT7_API_KEY = \"CONTEXT7_API_KEY\""
            }
        }
    ' "$config" > "$tmp"
    mv -f "$tmp" "$config"
}

remove_generated_context7_rule() {
    local file="$1"
    local tmp

    [ -f "$file" ] || return 0

    tmp="$(mktemp)"
    awk '
        /^<!-- context7 -->$/ {
            skip = !skip
            next
        }
        !skip {
            print
        }
    ' "$file" > "$tmp"
    mv -f "$tmp" "$file"
}

if [ "${DOTFILES_INSTALL_CONTEXT7:-}" = "1" ] || [ -n "${CONTEXT7_API_KEY:-}" ]; then
    if command -v npx >/dev/null 2>&1; then
        args=(-y ctx7@latest setup --claude --codex --mcp --yes)
        if [ -n "${CONTEXT7_API_KEY:-}" ]; then
            args+=(--api-key "$CONTEXT7_API_KEY")
        fi
        npx "${args[@]}" || echo "Context7 setup failed (non-fatal)"
    else
        echo "npx not found, skipping Context7 setup (non-fatal)"
    fi
else
    echo "Context7 setup skipped. Set DOTFILES_INSTALL_CONTEXT7=1 or CONTEXT7_API_KEY to run it."
fi

normalize_codex_config "$CONFIG"
remove_generated_context7_rule "$AGENTS"
echo "Context7 setup normalized"
